# MD / Vector 库（略）
MD_PGHOST=
MD_PGDATABASE=neondb
MD_PGUSER=
MD_PGPASSWORD=
VECTOR_PGHOST=
VECTOR_PGDATABASE=neondb
VECTOR_PGUSER=
VECTOR_PGPASSWORD=

# LLM
MODEL_NAME=deepseek-chat
API_KEY=
BASE_URL=https://api.deepseek.com

# RAG
RETRIEVAL_BACKEND=hybrid
EMBEDDING_DIM=512
CHUNK_SIZE=500
CHUNK_OVERLAP=80
RAG_TOP_K=5

# 多轮对话记忆（保留最近 N 轮 user+assistant）
MEMORY_MAX_TURNS=10

# MCP（pip install mcp-server-time mcp-server-fetch）
TIME_MCP_ENABLED=true
TIME_MCP_COMMAND=python
TIME_MCP_ARGS=-m mcp_server_time
MCP_TIMEZONE=Asia/Shanghai

FETCH_MCP_ENABLED=true
FETCH_MCP_COMMAND=python
FETCH_MCP_ARGS=-m mcp_server_fetch --ignore-robots-txt
FETCH_MAX_LENGTH=6000
WIKI_SEARCH_URL=https://leagueoflegends.fandom.com/wiki/Special:Search?query={query}
WIKI_FALLBACK_URL=https://en.wikipedia.org/w/index.php?search={query}

# 若已安装 uv，可改为：
# TIME_MCP_COMMAND=uvx
# TIME_MCP_ARGS=mcp-server-time
# FETCH_MCP_COMMAND=uvx
# FETCH_MCP_ARGS=mcp-server-fetch
